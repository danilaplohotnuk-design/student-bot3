# Скопіюй у .env і підстав свої значення.
# Локально в браузері: http://localhost:3000 (порт змінюється через PORT нижче)
# Пароль для режиму редагування в додатку та /admin.html — має збігатися з тим, що на сервері (Render тощо).
#
# --- Supabase + хмара (Render тощо) ---
# «Важливо»: задай SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY і виконай SQL з supabase/reminder.sql у проєкті Supabase.
#   Ключ service_role — лише в змінних сервера, ніколи у фронті / у репозиторії.
# Якщо Supabase не використовуєш — «Важливо» пишеться у файл; тоді потрібен DATA_DIR на Persistent Disk.
# Статистика (stats.json): той самий DATA_DIR або окремий STATS_FILE — щоб лічильники не обнулялись при деплої.

ADMIN_PASSWORD=change-me
PORT=3000

# Статистика унікальних заходів (POST /api/track/pageview): не рахувати cron-ботів і свій браузер
# За замовч. ігноруємо User-Agent, де є підрядки cron-job та console.cron (console.cron-job тощо)
# Додаткові підрядки через кому:
# STATS_EXCLUDE_UA_SUBSTR=somebot,other
# Свій відбиток (GET /api/admin/stats/self-fingerprint з заголовком x-admin-password) — через кому:
# STATS_EXCLUDE_FINGERPRINTS=abc123def456...

# Статистика зберігається у файл і переживає рестарт (не зникає при деплої, якщо диск постійний):
# — за замовч.: stats.json у корені проєкту (локально)
# — Render + Persistent Disk: той самий DATA_DIR, що й для reminder.json → …/stats.json
# — або явний шлях:
# STATS_FILE=/var/data/app-stats.json

# «Важливо» без платного Disk на Render — Supabase (безкоштовний план):
# 1) Створи проєкт на supabase.com, виконай SQL з supabase/reminder.sql
# 2) У Render → Environment додай:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (Settings → API → service_role, НЕ вставляй у фронт!)
#
# Якщо Supabase не заданий — використовується файл reminder.json:
# DATA_DIR=/var/data
# або REMINDER_FILE=/var/data/reminder.json

# Опційно: Telegram-бот
# BOT_TOKEN=
# WEBAPP_URL=https://твій-домен.onrender.com
