# Скопіюй у .env і підстав свої значення.
# Локально в браузері: http://localhost:3000 (порт змінюється через PORT нижче)
# Пароль для режиму редагування в додатку та /admin.html — має збігатися з тим, що на сервері (Render тощо).

ADMIN_PASSWORD=change-me
PORT=3000

# «Важливо» без платного Disk на Render — Supabase (безкоштовний план):
# 1) Створи проєкт на supabase.com, виконай SQL з supabase/reminder.sql
# 2) У Render → Environment додай:
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ... (Settings → API → service_role, НЕ вставляй у фронт!)
#
# Якщо Supabase не заданий — використовується файл reminder.json:
# DATA_DIR=/var/data
# або REMINDER_FILE=/var/data/reminder.json

# Опційно: Telegram-бот
# BOT_TOKEN=
# WEBAPP_URL=https://твій-домен.onrender.com
